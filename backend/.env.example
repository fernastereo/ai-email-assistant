# Server
PORT=3001
NODE_ENV=production

# OpenAI — get your key at platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# CORS — set to your Chrome extension ID once published
# Format: chrome-extension://<extension-id>
# In development you can use * but never in production
CORS_ORIGIN=chrome-extension://your-extension-id
