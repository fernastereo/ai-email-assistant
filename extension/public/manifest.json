{
  "manifest_version": 3,
  "name": "AI Email Assistant",
  "version": "1.0.0",
  "description": "AI Email Assistant. Sugiere respuestas, resume emails, mejora la redacción y detecta el tono de tus emails.",
  "permissions": [
    "contextMenus",
    "tabs",
    "sidePanel",
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://ai-email-assistant.vercel.app/*"
  ],
  "background": {
    "service_worker": "static/js/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*", 
        "https://outlook.live.com/*", 
        "https://outlook.office.com/*"
      ],
      "js": ["static/js/content-script.js"],
      "css": ["static/css/content-styles.css"],
      "type": "module"
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "AI Email Assistant"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html", "assets/*"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}